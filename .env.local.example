# ── REQUIRED FOR PRODUCTION ──────────────────────────────────────
# Without these, the contact form falls back to a no-op success
# response and writes nothing to the database.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required once auth (Slice 1) is wired up.
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://app.trdepledgegardeningandmaintenance.com


# ── ADDED POST-DEPLOYMENT VIA ADMIN SETTINGS ─────────────────────
# All optional. Each integration degrades gracefully if missing.

XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=

SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=

NEXT_PUBLIC_ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Email (Resend). Required for email-on-enquiry; SMS + push still work without.
RESEND_API_KEY=
RESEND_FROM=T.R. Depledge <enquiries@trdepledgegardeningandmaintenance.com>

# Notification destination for new website enquiries.
ENQUIRY_NOTIFY_EMAIL=t.rdepledge@outlook.com
